---

<section class="section building" id="building">
  <div class="shell">
    <span class="eyebrow" data-reveal>02 / Building — work in progress</span>

    <div class="building__grid">
      <div class="building__copy">
        <h2 class="section-title" data-reveal>Xelsius</h2>
        <p class="building__tagline" data-reveal>A side project in AI for accounting.</p>
        <p class="building__body" data-reveal>
          I'm exploring how an agent could read financial data and propose
          <strong>reviewable, deterministic diffs</strong> — changes a person approves rather
          than a black box decides. Early days, but it's the kind of tool I wish I'd had when
          I did this work by hand.
        </p>
        <div class="building__tags" data-reveal>
          <span class="tag">TypeScript</span>
          <span class="tag">LLM agents</span>
          <span class="tag">Deterministic diffs</span>
          <span class="tag">Fintech</span>
        </div>
        <div class="building__links" data-reveal>
          <a href="https://github.com/dingtianding/Xelsius" target="_blank" rel="noopener" class="building__link">
            View repository ↗
          </a>
          <span class="building__status"><span class="status-dot"></span>Personal project · early</span>
        </div>
      </div>

      <!-- Stylized product mock: a diff the agent might propose.
           Lines reveal line-by-line as the section scrolls
           through view (see motion.ts). -->
      <div class="terminal" data-terminal aria-hidden="true">
        <div class="terminal__bar">
          <span class="terminal__dots"><i></i><i></i><i></i></span>
          <span class="terminal__title">reconciliation.diff</span>
        </div>
        <pre class="terminal__body"><code><span class="t-line c-dim">@@ ledger/Q3 · 1,204 rows scanned @@</span>
<span class="t-line c-dim">  acct 4100  Revenue</span>
<span class="t-line c-del">- 1010  Cash            $48,200.00   <span class="c-note">unmatched</span></span>
<span class="t-line c-add">+ 1010  Cash            $48,200.00   <span class="c-note">→ INV-3471</span></span>
<span class="t-line c-dim">  acct 5200  COGS</span>
<span class="t-line c-del">- 2000  AP              $ 9,118.40   <span class="c-note">dup</span></span>
<span class="t-line c-add">+ 2000  AP              $ 9,118.40   <span class="c-note">merged 2</span></span>
<span class="t-line c-sig">  ▸ 3 changes · 0 unbalanced · <span class="t-approve">approve?</span></span></code></pre>
      </div>
    </div>
  </div>
</section>

<style>
  .building {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background:
      radial-gradient(80% 120% at 100% 0%, rgba(232, 178, 90, 0.025), transparent 55%);
  }
  .building__grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }
  .building__tagline {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--signal);
    font-size: clamp(1.1rem, 1rem + 0.6vw, 1.5rem);
    margin-top: 0.6rem;
  }
  .building__body {
    margin-top: 1.1rem;
    max-width: 52ch;
    color: var(--text-dim);
    font-size: 1.08rem;
  }
  .building__body strong { color: var(--text); font-weight: 600; }
  .building__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.4rem;
  }
  .building__links {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    flex-wrap: wrap;
    margin-top: 1.6rem;
    font-family: var(--font-mono);
    font-size: 0.84rem;
  }
  .building__link {
    color: var(--text);
    border-bottom: 1px solid var(--signal);
    padding-bottom: 2px;
    transition: color 0.2s ease;
  }
  .building__link:hover { color: var(--signal); }
  .building__status { color: var(--text-faint); display: inline-flex; align-items: center; gap: 0.5em; }
  .status-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--signal);
    box-shadow: 0 0 8px var(--signal);
    animation: glow 1.8s ease-in-out infinite;
  }
  @keyframes glow { 50% { opacity: 0.4; } }

  /* terminal mock */
  .terminal {
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    overflow: hidden;
    background: #08080a;
    box-shadow: 0 30px 80px -30px rgba(0, 0, 0, 0.8);
  }
  .terminal__bar {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--line);
    background: var(--bg-elev);
  }
  .terminal__dots { display: inline-flex; gap: 0.4rem; }
  .terminal__dots i {
    width: 11px; height: 11px; border-radius: 50%;
    background: var(--line-strong);
  }
  .terminal__dots i:first-child { background: var(--del); }
  .terminal__title {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--text-faint);
  }
  .terminal__body {
    padding: 1.2rem 1.3rem;
    font-family: var(--font-mono);
    font-size: clamp(0.7rem, 0.6rem + 0.4vw, 0.84rem);
    line-height: 1.85;
    overflow-x: auto;
  }
  .c-dim { color: var(--text-faint); }
  .c-del { color: var(--del); display: block; }
  .c-add { color: var(--add); display: block; }
  .c-sig { color: var(--signal); display: block; margin-top: 0.4rem; }
  .c-note { color: var(--text-faint); font-style: italic; }

  /* "approve?" lights up once the whole diff has resolved. */
  .t-approve {
    border-radius: 4px;
    padding: 0.05em 0.35em;
    transition: background 0.4s ease, color 0.4s ease, box-shadow 0.4s ease;
  }
  .terminal.is-resolved .t-approve {
    background: var(--signal);
    color: #0a0a0c;
    box-shadow: 0 0 18px -2px rgba(232, 178, 90, 0.55);
  }

  @media (prefers-reduced-motion: reduce) {
    .t-line { opacity: 1 !important; }
  }

  @media (min-width: 900px) {
    .building__grid { grid-template-columns: 1fr 1fr; }
  }
</style>
