---
const links = [
  { label: 'About', href: '#about' },
  { label: 'Building', href: '#building' },
  { label: 'Work', href: '#work' },
  { label: 'Stack', href: '#stack' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="nav">
  <div class="shell nav__inner">
    <a class="nav__brand" href="#top">
      <span class="nav__mark">DD</span>
      <span class="nav__path">dean_ding<span class="blink">_</span></span>
    </a>
    <nav class="nav__links" aria-label="Primary">
      {links.map((l, i) => (
        <a href={l.href}>
          <span class="nav__num">0{i + 1}</span>{l.label}
        </a>
      ))}
    </nav>
    <div class="nav__end">
      <button
        class="nav__cmdk"
        type="button"
        aria-label="Open command palette (Command-K)"
        onclick="window.dispatchEvent(new CustomEvent('cmdk:open'))"
      >
        <span class="nav__cmdk-glyph">⌘</span>K
      </button>
      <a class="nav__cta" href="/resume.pdf" target="_blank" rel="noopener" data-magnetic>Résumé ↗</a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 50;
    backdrop-filter: blur(10px);
    background: linear-gradient(to bottom, rgba(10, 10, 12, 0.85), rgba(10, 10, 12, 0.4));
    border-bottom: 1px solid var(--line);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .nav__brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }
  .nav__mark {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border: 1px solid var(--line-strong);
    border-radius: 7px;
    font-weight: 700;
    color: var(--signal);
    letter-spacing: 0.05em;
  }
  .nav__path { color: var(--text-dim); }
  .blink { animation: blink 1.1s steps(2) infinite; color: var(--signal); }
  @keyframes blink { 0%, 50% { opacity: 1; } 51%, 100% { opacity: 0; } }

  .nav__links {
    display: flex;
    gap: 1.6rem;
    font-size: 0.9rem;
  }
  .nav__links a {
    color: var(--text-dim);
    transition: color 0.2s ease;
    position: relative;
  }
  .nav__links a:hover { color: var(--text); }
  .nav__links a.is-active { color: var(--text); }
  .nav__links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -6px;
    height: 1px;
    width: 100%;
    background: var(--signal);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  .nav__links a.is-active::after { transform: scaleX(1); }
  .nav__num {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--signal);
    margin-right: 0.4em;
    opacity: 0.7;
  }

  .nav__end { display: flex; align-items: center; gap: 0.8rem; }
  .nav__cmdk {
    display: inline-flex;
    align-items: center;
    gap: 0.15em;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 7px;
    padding: 0.35em 0.6em;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .nav__cmdk:hover { border-color: var(--line-strong); color: var(--text); }
  .nav__cmdk-glyph { font-size: 0.9em; }

  .nav__cta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.45em 1em;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .nav__cta:hover { border-color: var(--signal); color: var(--signal); }

  @media (max-width: 480px) {
    .nav__cmdk { display: none; }
  }

  @media (max-width: 760px) {
    .nav__links { display: none; }
  }
</style>
