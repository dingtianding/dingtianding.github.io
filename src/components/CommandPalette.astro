---
// ⌘K command palette, the "chart of accounts".
// Operator-grade navigation: fuzzy-filter to jump to any section
// or run an action. Progressive enhancement, if JS is off, the
// normal nav links still work and this never appears.
---

<div class="cmdk" data-cmdk hidden aria-hidden="true">
  <div class="cmdk__backdrop" data-cmdk-close></div>
  <div class="cmdk__panel" role="dialog" aria-modal="true" aria-label="Command palette">
    <div class="cmdk__bar">
      <span class="cmdk__prompt" aria-hidden="true">›</span>
      <input
        class="cmdk__input"
        type="text"
        placeholder="Jump to a section, or run an action…"
        aria-label="Command"
        autocomplete="off"
        autocorrect="off"
        spellcheck="false"
      />
      <kbd class="cmdk__esc">esc</kbd>
    </div>
    <ul class="cmdk__list" role="listbox" aria-label="Commands"></ul>
    <div class="cmdk__foot">
      <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
      <span><kbd>↵</kbd> select</span>
      <span class="cmdk__brand">chart of accounts</span>
    </div>
  </div>
</div>

<script>
  type Cmd = {
    id: string;
    label: string;
    hint: string;
    group: 'Jump to' | 'Actions' | 'Meta';
    tag: string; // leading mono glyph / account code
    run: (item: HTMLElement) => void;
  };

  const root = document.querySelector<HTMLElement>('[data-cmdk]');
  if (root) {
    const panel = root.querySelector<HTMLElement>('.cmdk__panel')!;
    const input = root.querySelector<HTMLInputElement>('.cmdk__input')!;
    const list = root.querySelector<HTMLUListElement>('.cmdk__list')!;
    const lenis = () => (window as any).__lenis;

    const jump = (hash: string) => () => {
      const target = document.querySelector(hash) as HTMLElement | null;
      if (!target) return;
      const l = lenis();
      if (l) l.scrollTo(target, { offset: -72 });
      else target.scrollIntoView({ behavior: 'smooth' });
    };
    const open = (href: string) => () => window.open(href, '_blank', 'noopener');
    const go = (href: string) => () => { window.location.href = href; };

    const commands: Cmd[] = [
      { id: 'about', label: 'About: opening balance', hint: 'section 01', group: 'Jump to', tag: '01', run: jump('#about') },
      { id: 'building', label: 'Building: work in progress', hint: 'section 02', group: 'Jump to', tag: '02', run: jump('#building') },
      { id: 'work', label: 'Work: posted, verified', hint: 'section 03', group: 'Jump to', tag: '03', run: jump('#work') },
      { id: 'stack', label: 'Stack: assets on the books', hint: 'section 04', group: 'Jump to', tag: '04', run: jump('#stack') },
      { id: 'contact', label: 'Contact: close the books', hint: 'section 05', group: 'Jump to', tag: '05', run: jump('#contact') },
      { id: 'top', label: 'Back to top', hint: 'hero', group: 'Jump to', tag: '↑', run: jump('#top') },

      { id: 'ask', label: 'Try the grounded-answer demo', hint: '/ask', group: 'Actions', tag: '◎', run: go('/ask') },
      { id: 'resume', label: 'Download résumé', hint: 'PDF', group: 'Actions', tag: '⇩', run: open('/resume.pdf') },
      {
        id: 'email',
        label: 'Copy email address',
        hint: 'dingtian.ding@gmail.com',
        group: 'Actions',
        tag: '⧉',
        run: (item) => {
          navigator.clipboard?.writeText('dingtian.ding@gmail.com').then(() => {
            const label = item.querySelector<HTMLElement>('.cmdk__item-label');
            if (label) {
              const prev = label.textContent;
              label.textContent = 'Copied ✓';
              item.classList.add('is-done');
              setTimeout(() => close(), 650);
              setTimeout(() => {
                label.textContent = prev;
                item.classList.remove('is-done');
              }, 900);
            }
          });
        },
      },
      { id: 'github', label: 'Open GitHub', hint: 'github.com/dingtianding', group: 'Actions', tag: '↗', run: open('https://github.com/dingtianding') },
      { id: 'linkedin', label: 'Open LinkedIn', hint: 'in/deanding', group: 'Actions', tag: '↗', run: open('https://www.linkedin.com/in/deanding/') },

      { id: 'source', label: 'View source of this site', hint: 'the repo', group: 'Meta', tag: '⌥', run: open('https://github.com/dingtianding/dingtianding.github.io') },
    ];

    let filtered: Cmd[] = commands;
    let active = 0;

    // Subsequence fuzzy match; returns a score or -1 if no match.
    const score = (q: string, text: string): number => {
      if (!q) return 0;
      q = q.toLowerCase();
      text = text.toLowerCase();
      let ti = 0;
      let s = 0;
      let streak = 0;
      for (const ch of q) {
        const found = text.indexOf(ch, ti);
        if (found === -1) return -1;
        streak = found === ti ? streak + 1 : 0;
        s += 1 + streak;
        ti = found + 1;
      }
      return s;
    };

    const render = () => {
      list.innerHTML = '';
      let idx = 0;
      let lastGroup = '';
      for (const cmd of filtered) {
        if (cmd.group !== lastGroup) {
          const g = document.createElement('li');
          g.className = 'cmdk__group';
          g.textContent = cmd.group;
          g.setAttribute('aria-hidden', 'true');
          list.appendChild(g);
          lastGroup = cmd.group;
        }
        const li = document.createElement('li');
        li.className = 'cmdk__item';
        li.setAttribute('role', 'option');
        li.dataset.index = String(idx);
        if (idx === active) li.classList.add('is-active');
        li.innerHTML =
          `<span class="cmdk__tag">${cmd.tag}</span>` +
          `<span class="cmdk__item-label">${cmd.label}</span>` +
          `<span class="cmdk__item-hint">${cmd.hint}</span>`;
        const i = idx;
        li.addEventListener('mousemove', () => setActive(i));
        li.addEventListener('click', () => exec(i));
        list.appendChild(li);
        idx++;
      }
    };

    const setActive = (i: number) => {
      active = Math.max(0, Math.min(i, filtered.length - 1));
      list.querySelectorAll<HTMLElement>('.cmdk__item').forEach((el) => {
        el.classList.toggle('is-active', Number(el.dataset.index) === active);
      });
      const el = list.querySelector<HTMLElement>('.cmdk__item.is-active');
      el?.scrollIntoView({ block: 'nearest' });
    };

    const filter = (q: string) => {
      filtered = q
        ? commands
            .map((c) => ({ c, s: Math.max(score(q, c.label), score(q, c.id), score(q, c.hint)) }))
            .filter((r) => r.s >= 0)
            .sort((a, b) => b.s - a.s)
            .map((r) => r.c)
        : commands;
      active = 0;
      render();
    };

    const exec = (i: number) => {
      const cmd = filtered[i];
      if (!cmd) return;
      const item = list.querySelector<HTMLElement>(`.cmdk__item[data-index="${i}"]`);
      // Copy handles its own close timing; everything else closes first so
      // Lenis is restarted before a section jump calls scrollTo (otherwise
      // the jump fires while smooth-scroll is still paused and is lost).
      if (cmd.id === 'email') {
        cmd.run(item!);
      } else {
        close();
        cmd.run(item!);
      }
    };

    let lastFocus: HTMLElement | null = null;
    const isOpen = () => !root.hasAttribute('hidden');

    const open_ = () => {
      if (isOpen()) return;
      lastFocus = document.activeElement as HTMLElement;
      root.removeAttribute('hidden');
      root.setAttribute('aria-hidden', 'false');
      lenis()?.stop();
      input.value = '';
      filter('');
      // Force a style flush so the enter transition plays deterministically,
      // without depending on rAF (which throttles in background tabs).
      void root.offsetWidth;
      root.classList.add('is-open');
      input.focus();
    };
    const close = () => {
      if (!isOpen()) return;
      root.classList.remove('is-open');
      lenis()?.start();
      const done = () => {
        root.setAttribute('hidden', '');
        root.setAttribute('aria-hidden', 'true');
        panel.removeEventListener('transitionend', done);
      };
      // Fall back if transitions are disabled (reduced motion).
      panel.addEventListener('transitionend', done);
      setTimeout(done, 220);
      lastFocus?.focus();
    };

    // ---- wiring ----
    input.addEventListener('input', () => filter(input.value));
    root.querySelector('[data-cmdk-close]')?.addEventListener('click', close);

    root.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { e.preventDefault(); close(); }
      else if (e.key === 'ArrowDown') { e.preventDefault(); setActive(active + 1); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(active - 1); }
      else if (e.key === 'Enter') { e.preventDefault(); exec(active); }
      else if (e.key === 'Tab') { e.preventDefault(); } // trap focus on the input
    });

    window.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        isOpen() ? close() : open_();
      }
    });
    window.addEventListener('cmdk:open', open_ as EventListener);
  }
</script>

<!-- Global (not scoped): the list items are created in JS and would
     not carry Astro's scoping attribute, so scoped rules would miss
     them. All selectors are .cmdk-prefixed, so there is no leakage. -->
<style is:global>
  .cmdk {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: start center;
    padding-top: 14vh;
  }
  .cmdk[hidden] { display: none; }

  .cmdk__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(6, 6, 8, 0.72);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.18s ease;
  }
  .cmdk.is-open .cmdk__backdrop { opacity: 1; }

  .cmdk__panel {
    position: relative;
    width: min(92vw, 620px);
    background: #0c0c0f;
    border: 1px solid var(--line-strong);
    border-radius: 14px;
    box-shadow: 0 40px 100px -30px rgba(0, 0, 0, 0.85);
    overflow: hidden;
    transform: translateY(-8px) scale(0.985);
    opacity: 0;
    transition: transform 0.2s cubic-bezier(0.2, 0.7, 0.2, 1), opacity 0.2s ease;
  }
  .cmdk.is-open .cmdk__panel { transform: none; opacity: 1; }

  .cmdk__bar {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.9rem 1.1rem;
    border-bottom: 1px solid var(--line);
  }
  .cmdk__prompt { font-family: var(--font-mono); color: var(--signal); font-size: 1.1rem; }
  .cmdk__input {
    flex: 1;
    background: transparent;
    border: 0;
    outline: 0;
    color: var(--text);
    font-family: var(--font-body);
    font-size: var(--fs-md);
  }
  .cmdk__input::placeholder { color: var(--text-faint); }
  .cmdk__esc {
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    color: var(--text-faint);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 0.15em 0.45em;
  }

  .cmdk__list {
    list-style: none;
    max-height: 46vh;
    overflow-y: auto;
    padding: 0.5rem;
  }
  .cmdk__group {
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-faint);
    padding: 0.7rem 0.7rem 0.35rem;
  }
  .cmdk__item {
    display: grid;
    grid-template-columns: 1.6rem 1fr auto;
    align-items: center;
    gap: 0.7rem;
    padding: 0.6rem 0.7rem;
    border-radius: 9px;
    cursor: pointer;
    color: var(--text-dim);
  }
  .cmdk__item.is-active { background: rgba(232, 178, 90, 0.12); color: var(--text); }
  .cmdk__item.is-active .cmdk__tag { color: var(--signal); }
  .cmdk__item.is-done { color: var(--add); }
  .cmdk__tag {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--text-faint);
    text-align: center;
  }
  .cmdk__item-label { font-size: var(--fs-sm); }
  .cmdk__item-hint {
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    color: var(--text-faint);
    white-space: nowrap;
  }

  .cmdk__foot {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 0.6rem 1.1rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    color: var(--text-faint);
  }
  .cmdk__foot kbd {
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 0.05em 0.35em;
    margin-right: 0.15em;
  }
  .cmdk__brand { margin-left: auto; color: var(--signal); opacity: 0.7; }

  @media (prefers-reduced-motion: reduce) {
    .cmdk__backdrop, .cmdk__panel { transition: none; }
  }
</style>
