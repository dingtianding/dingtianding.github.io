---
import { projects } from '../data/projects';

// Xelsius is showcased in the "Building" section; the rest live here.
const items = projects.filter((p) => p.name !== 'Xelsius');
---

<section class="section work" id="work">
  <div class="shell">
    <div class="work__head">
      <span class="eyebrow" data-reveal>03 / Selected work</span>
      <h2 class="section-title" data-reveal>Things I've shipped.</h2>
    </div>

    <div class="work__grid">
      {items.map((p) => (
        <article class="card" data-reveal>
          {p.image && (
            <div class="card__media">
              <img src={p.image} alt={`${p.name} screenshot`} loading="lazy" />
            </div>
          )}
          <div class="card__content">
            <header class="card__top">
              <h3 class="card__title">{p.name}</h3>
              <div class="card__badges">
                {p.handCoded && (
                  <span class="card__handcoded" title="Written by hand — not AI-generated">
                    &lt;/&gt; Hand-coded
                  </span>
                )}
                {p.award && <span class="card__award">{p.award}</span>}
              </div>
            </header>
            <p class="card__blurb">{p.blurb}</p>
            <ul class="card__tech">
              {p.tech.map((t) => <li>{t}</li>)}
            </ul>
            <div class="card__links">
              {p.links.map((l) => (
                <a href={l.href} target="_blank" rel="noopener">{l.label} ↗</a>
              ))}
              {p.links.length === 0 && p.isPrivate && (
                <span class="card__private">Private repository</span>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .work__head { margin-bottom: 2.6rem; }
  .work__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.4rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-card);
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.2, 0.7, 0.2, 1), border-color 0.3s ease;
    will-change: transform;
  }
  .card:hover {
    transform: translateY(-6px);
    border-color: var(--line-strong);
  }

  .card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background: var(--bg-elev);
  }
  .card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.35) brightness(0.92);
    transition: transform 0.5s ease, filter 0.4s ease;
  }
  .card:hover .card__media img {
    transform: scale(1.04);
    filter: grayscale(0) brightness(1);
  }

  .card__content {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.4rem;
    flex: 1;
  }
  .card__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .card__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.35rem;
    letter-spacing: -0.01em;
  }
  .card__badges {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
    flex-shrink: 0;
  }
  .card__handcoded {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    color: var(--add);
    border: 1px solid rgba(70, 192, 90, 0.3);
    background: rgba(70, 192, 90, 0.06);
    border-radius: 999px;
    padding: 0.25em 0.6em;
    white-space: nowrap;
  }
  .card__award {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--signal);
    border: 1px solid rgba(232, 178, 90, 0.3);
    border-radius: 999px;
    padding: 0.25em 0.6em;
    white-space: nowrap;
  }
  .card__blurb {
    color: var(--text-dim);
    font-size: 0.95rem;
    line-height: 1.55;
    flex: 1;
  }
  .card__tech {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-faint);
  }
  .card__tech li::before { content: '· '; color: var(--signal); }
  .card__links {
    display: flex;
    gap: 1.2rem;
    padding-top: 0.4rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
  .card__links a {
    color: var(--text-dim);
    transition: color 0.2s ease;
  }
  .card__links a:hover { color: var(--signal); }
  .card__private {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-faint);
  }
</style>
