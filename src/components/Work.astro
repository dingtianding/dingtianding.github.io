---
import { projects } from '../data/projects';
import { repoForLinks, fetchRepoStats } from '../data/github';
import Card from './Card.astro';

// The DCB suite lives in the "Building" section (02); everything else, including
// the earlier Xelsius build, gets a card here.
const items = projects.filter((p) => !p.name.startsWith('DCB '));

// Pull live GitHub figures at build time and merge them in by repo,
// so each project reads as a posted, verified ledger entry.
const repoByName = new Map(items.map((p) => [p.name, repoForLinks(p.links)] as const));
const stats = await fetchRepoStats(
  [...repoByName.values()].filter((r): r is string => r !== null),
);
const rows = items.map((p) => ({ p, st: repoByName.get(p.name) ? stats[repoByName.get(p.name)!] : undefined }));
---

<section class="section work" id="work">
  <div class="shell">
    <div class="work__head">
      <span class="eyebrow" data-reveal>03 / Work: posted &amp; verified</span>
      <h2 class="section-title" data-reveal>Things I've shipped.</h2>
    </div>

    <div class="work__grid">
      {rows.map(({ p, st }) => <Card p={p} st={st} />)}
    </div>
  </div>
</section>

<style>
  .work__head { margin-bottom: 2.6rem; }
  .work__grid {
    display: grid;
    /* min() guards against overflow when the viewport is narrower than 320px */
    grid-template-columns: repeat(auto-fill, minmax(min(360px, 100%), 1fr));
    gap: 1.4rem;
  }
</style>
