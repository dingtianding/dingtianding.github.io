---
import { projects } from '../data/projects';
import { repoForLinks, fetchRepoStats, relativeTime } from '../data/github';

// The DCB suite is featured in the "Building" section; every project — including
// the earlier Xelsius build — gets a card here.
const items = projects;

// Pull live GitHub figures at build time and merge them in by repo,
// so each project reads as a posted, verified ledger entry.
const repoByName = new Map(items.map((p) => [p.name, repoForLinks(p.links)] as const));
const stats = await fetchRepoStats(
  [...repoByName.values()].filter((r): r is string => r !== null),
);
const rows = items.map((p) => ({ p, st: repoByName.get(p.name) ? stats[repoByName.get(p.name)!] : undefined }));
---

<section class="section work" id="work">
  <div class="shell">
    <div class="work__head">
      <span class="eyebrow" data-reveal>03 / Work — posted &amp; verified</span>
      <h2 class="section-title" data-reveal>Things I've shipped.</h2>
      <p class="work__more" data-reveal>
        The DCB projects are one system — <a href="/dcb-system">see how they fit together →</a>
      </p>
    </div>

    <div class="work__grid">
      {rows.map(({ p, st }) => (
        <article class="card" data-reveal>
          {p.image && (
            <div class="card__media">
              <img src={p.image} alt={`${p.name} screenshot`} loading="lazy" />
            </div>
          )}
          <div class="card__content">
            <header class="card__top">
              <h3 class="card__title">{p.name}</h3>
              <div class="card__badges">
                {p.handCoded && (
                  <span class="card__handcoded" title="Written by hand — not AI-generated">
                    &lt;/&gt; Hand-coded
                  </span>
                )}
                {p.award && <span class="card__award">{p.award}</span>}
              </div>
            </header>
            <p class="card__blurb">{p.blurb}</p>
            <ul class="card__tech">
              {p.tech.map((t) => <li>{t}</li>)}
            </ul>

            {/* Live, build-time GitHub figures rendered as an audited
                ledger line — verified = links to a real public repo. */}
            {(st || p.isPrivate) && (
              <div class="card__ledger" aria-label="Repository facts">
                {st?.language && (
                  <span class="led"><span class="led__k">lang</span> {st.language}</span>
                )}
                {st && st.stars >= 3 && (
                  <span class="led"><span class="led__k">★</span> {st.stars}</span>
                )}
                {st?.pushedAt && (
                  <span class="led"><span class="led__k">last</span> {relativeTime(st.pushedAt)}</span>
                )}
                {st && <span class="led led--ok">verified ✓</span>}
                {!st && p.isPrivate && <span class="led led--muted">private · on file</span>}
              </div>
            )}

            {p.links.length > 0 && (
              <div class="card__links">
                {p.links.map((l) => (
                  <a href={l.href} target="_blank" rel="noopener">{l.label} ↗</a>
                ))}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .work__head { margin-bottom: 2.6rem; }
  .work__more {
    margin-top: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.86rem;
    color: var(--text-dim);
  }
  .work__more a {
    color: var(--text);
    border-bottom: 1px solid var(--signal);
    padding-bottom: 1px;
    transition: color 0.2s ease;
  }
  .work__more a:hover { color: var(--signal); }
  .work__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.4rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-card);
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.2, 0.7, 0.2, 1), border-color 0.3s ease;
    will-change: transform;
  }
  .card:hover {
    transform: translateY(-6px);
    border-color: var(--line-strong);
  }

  .card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background: var(--bg-elev);
  }
  .card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.35) brightness(0.92);
    transition: transform 0.5s ease, filter 0.4s ease;
  }
  .card:hover .card__media img {
    transform: scale(1.04);
    filter: grayscale(0) brightness(1);
  }

  .card__content {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.4rem;
    flex: 1;
  }
  .card__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .card__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.35rem;
    letter-spacing: -0.01em;
  }
  .card__badges {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
    flex-shrink: 0;
  }
  .card__handcoded {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    color: var(--add);
    border: 1px solid rgba(70, 192, 90, 0.3);
    background: rgba(70, 192, 90, 0.06);
    border-radius: 999px;
    padding: 0.25em 0.6em;
    white-space: nowrap;
  }
  .card__award {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--signal);
    border: 1px solid rgba(232, 178, 90, 0.3);
    border-radius: 999px;
    padding: 0.25em 0.6em;
    white-space: nowrap;
  }
  .card__blurb {
    color: var(--text-dim);
    font-size: 0.95rem;
    line-height: 1.55;
    flex: 1;
  }
  .card__tech {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-faint);
  }
  .card__tech li::before { content: '· '; color: var(--signal); }
  /* Audited ledger strip — live GitHub figures as line-items. */
  .card__ledger {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.9rem;
    padding-top: 0.65rem;
    border-top: 1px dashed var(--line);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
  }
  .led { display: inline-flex; align-items: center; gap: 0.4em; white-space: nowrap; }
  .led__k { color: var(--text-faint); }
  .led--ok {
    margin-left: auto;
    color: var(--add);
    transform-origin: center;
  }
  .led--muted { margin-left: auto; color: var(--text-faint); font-style: italic; }

  .card__links {
    display: flex;
    gap: 1.2rem;
    padding-top: 0.4rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
  /* When a ledger strip is present, avoid a double rule. */
  .card__ledger + .card__links {
    border-top: none;
    padding-top: 0.7rem;
  }
  .card__links a {
    color: var(--text-dim);
    transition: color 0.2s ease;
  }
  .card__links a:hover { color: var(--signal); }
  .card__private {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-faint);
  }
</style>
