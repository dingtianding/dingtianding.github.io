---
const channels = [
  { label: 'Email', value: 'dingtian.ding@gmail.com', href: 'mailto:dingtian.ding@gmail.com' },
  { label: 'Phone', value: '917-436-2093', href: 'tel:+19174362093' },
  { label: 'LinkedIn', value: '/in/deanding', href: 'https://www.linkedin.com/in/deanding/' },
  { label: 'GitHub', value: '@dingtianding', href: 'https://github.com/dingtianding' },
  { label: 'Résumé', value: 'download PDF', href: '/resume.pdf' },
];
---

<section class="section contact" id="contact">
  <div class="shell">
    <span class="eyebrow" data-reveal>05 / Contact — close the books</span>
    <h2 class="contact__title" data-reveal>
      Building something at the<br />
      <span class="contact__accent">intersection of finance & AI?</span>
    </h2>
    <p class="contact__lede" data-reveal>
      I'm always up for a conversation about hard problems in the domain I came from.
      The fastest way to reach me is email.
    </p>

    <div class="contact__list" data-reveal>
      {channels.map((c) => (
        <a class="channel" href={c.href} target="_blank" rel="noopener">
          <span class="channel__label">{c.label}</span>
          <span class="channel__value">{c.value}</span>
          <span class="channel__arrow">↗</span>
        </a>
      ))}
    </div>
  </div>
</section>

<footer class="footer">
  <div class="shell footer__inner">
    <span>© <span id="year">2026</span> Dean Ding · <span class="footer__signed">reconciled ✓</span></span>
    <span class="footer__built">Built with Astro · GSAP · Lenis</span>
    <a href="#top">Back to top ↑</a>
  </div>
</footer>

<style>
  .contact { text-align: left; }
  .contact__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-3xl);
    line-height: var(--lh-tight);
    letter-spacing: -0.025em;
    margin-top: 1.2rem;
  }
  .contact__accent { color: var(--signal); }
  .contact__lede {
    margin-top: 1.4rem;
    max-width: 50ch;
    color: var(--text-dim);
    font-size: var(--fs-lg);
  }

  .contact__list {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 1fr;
    border-top: 1px solid var(--line);
  }
  .channel {
    display: grid;
    grid-template-columns: 160px 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1.3rem 0.4rem;
    border-bottom: 1px solid var(--line);
    transition: padding 0.3s ease, background 0.3s ease;
  }
  .channel:hover {
    padding-inline: 1.2rem;
    background: var(--bg-elev);
  }
  .channel__label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-faint);
  }
  .channel__value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-xl);
    color: var(--text);
    transition: color 0.2s ease;
  }
  .channel:hover .channel__value { color: var(--signal); }
  .channel__arrow {
    font-family: var(--font-mono);
    color: var(--text-faint);
    transition: transform 0.25s ease, color 0.2s ease;
  }
  .channel:hover .channel__arrow {
    transform: translate(3px, -3px);
    color: var(--signal);
  }

  .footer {
    border-top: 1px solid var(--line);
    padding-block: 2rem;
  }
  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--text-faint);
  }
  .footer__inner a { transition: color 0.2s ease; }
  .footer__inner a:hover { color: var(--signal); }
  .footer__signed { color: var(--add); }

  @media (max-width: 560px) {
    .channel { grid-template-columns: 1fr auto; }
    .channel__label { display: none; }
  }
</style>
