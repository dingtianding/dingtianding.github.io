---
// Ledger-style facts. Kept truthful and light — no invented metrics.
const ledger = [
  { k: 'Based in', v: 'New York City' },
  { k: 'Past life', v: 'Public accounting & tax' },
  { k: 'Now', v: 'Building AI for finance' },
  { k: 'Off the clock', v: 'Lifting & K-pop dance' },
];
---

<section class="section about" id="about">
  <div class="shell about__grid">
    <div class="about__head">
      <span class="eyebrow" data-reveal>01 / About — opening balance</span>
      <h2 class="section-title" data-reveal>
        I learned the problem<br />before I learned to code.
      </h2>
    </div>

    <div class="about__body">
      <p data-reveal>
        I spent the first chapter of my career in <strong>public accounting and private
        tax consulting</strong> — close enough to the numbers to feel exactly where the
        manual, error-prone, soul-draining work lived.
      </p>
      <p data-reveal>
        Then I went all-in on engineering: 1,000+ hours through App Academy, then a steady
        diet of shipping. JavaScript, React, Python, Rails, the cloud — but the real edge
        isn't the stack. It's that I understand the domain I'm automating.
      </p>
      <p data-reveal>
        Today I build <strong>vertical AI for accountants and finance teams</strong>:
        agents that propose deterministic, auditable changes a human can actually trust
        and approve. Between hackathon wins and side projects, the throughline is the same —
        software that removes the grind I used to do by hand.
      </p>

      <div class="portrait" data-reveal>
        <img src="/images/propic.jpeg" alt="Dean Ding" loading="lazy" width="96" height="96" />
        <div>
          <p class="portrait__name">Dean Ding</p>
          <p class="portrait__role">Engineer · ex-CPA · builder</p>
        </div>
      </div>
    </div>

    <aside class="about__ledger" data-reveal aria-label="Quick facts">
      {ledger.map((row) => (
        <div class="ledger-row">
          <span class="ledger-row__k">{row.k}</span>
          <span class="ledger-row__dots"></span>
          <span class="ledger-row__v">{row.v}</span>
        </div>
      ))}
    </aside>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 4rem);
  }
  .about__head { max-width: 60ch; }

  .about__body {
    display: grid;
    gap: 1.2rem;
    max-width: 62ch;
    color: var(--text-dim);
    font-size: var(--fs-md);
    line-height: var(--lh-normal);
  }
  .about__body strong { color: var(--text); font-weight: 600; }

  .portrait {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--line);
  }
  .portrait img {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--line-strong);
    filter: grayscale(0.2);
  }
  .portrait__name {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--text);
    font-size: 1.05rem;
  }
  .portrait__role {
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    color: var(--text-faint);
  }

  .about__ledger {
    display: grid;
    gap: 0.9rem;
    align-content: start;
    padding: 1.6rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-elev);
  }
  .ledger-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
  }
  .ledger-row__k { color: var(--text-faint); white-space: nowrap; }
  .ledger-row__dots {
    border-bottom: 1px dotted var(--line-strong);
    transform: translateY(-0.25em);
  }
  .ledger-row__v { color: var(--signal); white-space: nowrap; }

  @media (min-width: 900px) {
    .about__grid {
      grid-template-columns: 1.7fr 1fr;
      grid-template-areas:
        'head head'
        'body ledger';
      align-items: start;
    }
    .about__head { grid-area: head; }
    .about__body { grid-area: body; }
    .about__ledger { grid-area: ledger; position: sticky; top: 100px; }
  }
</style>
