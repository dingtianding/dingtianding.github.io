---
const socials = [
  { label: 'GitHub', href: 'https://github.com/dingtianding' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/deanding/' },
  { label: 'Email', href: 'mailto:dingtian.ding@gmail.com' },
];
---

<section class="hero" id="top">
  <div class="shell hero__inner">
    <p class="hero__kicker" data-reveal>
      <span class="dot"></span> Software Engineer · New York City
    </p>

    <h1 class="hero__name" data-reveal>
      Dean<br />Ding
    </h1>

    <!-- The conceptual hook: a career rendered as a git diff.
         Removed = the accountant. Added = the engineer.
         The real text lives in the markup (no-JS / reduced-motion
         see it instantly); motion.ts re-types it on load. -->
    <div class="diff" role="img" aria-label="From accountant to engineer" data-diff>
      <code class="diff__file" data-reveal>career.diff</code>
      <div class="diff__line diff__line--del">
        <span class="diff__sign">-</span>
        <span class="diff__text">spent years reconciling financial data by hand</span>
      </div>
      <div class="diff__line diff__line--add">
        <span class="diff__sign">+</span>
        <span class="diff__text">now I build the AI that does it deterministically</span>
        <span class="diff__caret" aria-hidden="true"></span>
      </div>
      <div class="diff__approve" aria-hidden="true">
        <span class="diff__approve-check">✓</span> 1 change · 0 unbalanced · approved
      </div>
    </div>

    <p class="hero__lede" data-reveal>
      A software engineer building Applied AI for finance: deterministic, reviewable systems
      instead of black-box answers. I've shipped production backends across fintech and
      healthcare, and I'm a CPA who lived the problems I now automate.
    </p>

    <div class="hero__actions" data-reveal>
      <a class="btn btn--primary" href="#building" data-magnetic>See what I'm building</a>
      <nav class="hero__socials" aria-label="Social links">
        {socials.map((s) => (
          <a href={s.href} target="_blank" rel="noopener">{s.label} ↗</a>
        ))}
      </nav>
    </div>
  </div>

  <div class="hero__scroll" data-reveal aria-hidden="true">
    <span>scroll</span>
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: 64px;
  }
  .hero__inner {
    width: 100%;
    display: grid;
    gap: 1.6rem;
    padding-block: clamp(3rem, 8vh, 6rem);
  }

  .hero__kicker {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: inline-flex;
    align-items: center;
    gap: 0.7em;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--add);
    box-shadow: 0 0 0 0 rgba(70, 192, 90, 0.5);
    animation: pulse 2.4s infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(70, 192, 90, 0.45); }
    70% { box-shadow: 0 0 0 9px rgba(70, 192, 90, 0); }
    100% { box-shadow: 0 0 0 0 rgba(70, 192, 90, 0); }
  }

  .hero__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-hero);
    line-height: 0.86;
    letter-spacing: -0.03em;
    margin-block: 0.2rem 0.4rem;
  }

  .diff {
    border-left: 2px solid var(--line-strong);
    padding-left: clamp(1rem, 2vw, 1.6rem);
    font-family: var(--font-mono);
    font-size: clamp(0.92rem, 0.85rem + 0.5vw, 1.18rem);
    display: grid;
    gap: 0.35rem;
    max-width: 46ch;
  }
  .diff__file {
    color: var(--text-faint);
    font-size: var(--fs-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.3rem;
  }
  .diff__line {
    display: flex;
    gap: 0.8em;
    padding: 0.18em 0.5em;
    border-radius: 5px;
  }
  .diff__sign { font-weight: 700; opacity: 0.85; }
  .diff__line--del {
    color: var(--del);
    background: rgba(240, 100, 88, 0.07);
  }
  /* Strike-through drawn as a scalable line so it can animate in
     as the accountant line is "removed". */
  .diff__line--del .diff__text {
    position: relative;
  }
  .diff__line--del .diff__text::after {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 100%;
    height: 1px;
    background: rgba(240, 100, 88, 0.55);
    transform: scaleX(var(--strike, 1));
    transform-origin: left center;
  }
  .diff__line--add {
    color: var(--add);
    background: rgba(70, 192, 90, 0.08);
    align-items: center;
  }

  /* Blinking write-cursor at the end of the added line. */
  .diff__caret {
    display: inline-block;
    width: 0.6em;
    height: 1.1em;
    margin-left: 0.1em;
    background: var(--add);
    opacity: 0;
    transform: translateY(0.1em);
  }
  .diff__caret.is-blinking { animation: caret-blink 1s steps(2) infinite; }
  @keyframes caret-blink { 0%, 50% { opacity: 1; } 51%, 100% { opacity: 0; } }

  /* Final resolution beat: the change is approved. */
  .diff__approve {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.02em;
    color: var(--signal);
    margin-top: 0.5rem;
    opacity: 0;
    transform: translateY(4px);
  }
  .diff__approve-check {
    display: inline-grid;
    place-items: center;
    width: 1.25em;
    height: 1.25em;
    border-radius: 50%;
    background: rgba(70, 192, 90, 0.15);
    color: var(--add);
    font-size: 0.8em;
    margin-right: 0.3em;
  }
  /* Reduced-motion / no-JS: show the resolved state, no caret. */
  @media (prefers-reduced-motion: reduce) {
    .diff__approve { opacity: 1; transform: none; }
    .diff__caret { display: none; }
  }

  .hero__lede {
    max-width: 52ch;
    color: var(--text-dim);
    font-size: var(--fs-lg);
    line-height: var(--lh-snug);
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 1.8rem;
    flex-wrap: wrap;
    margin-top: 0.6rem;
  }
  .btn {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    padding: 0.85em 1.4em;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    transition: transform 0.18s ease, background 0.2s ease, color 0.2s ease;
  }
  .btn--primary {
    background: var(--signal);
    color: #0a0a0c;
    border-color: var(--signal);
    font-weight: 500;
  }
  .btn--primary:hover { transform: translateY(-2px); }
  .hero__socials {
    display: flex;
    gap: 1.3rem;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--text-dim);
  }
  .hero__socials a { transition: color 0.2s ease; }
  .hero__socials a:hover { color: var(--signal); }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    right: var(--gutter);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .hero__scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(var(--signal), transparent);
    animation: drop 2s ease-in-out infinite;
    transform-origin: top;
  }
  @keyframes drop {
    0%, 100% { transform: scaleY(0.4); opacity: 0.4; }
    50% { transform: scaleY(1); opacity: 1; }
  }

  @media (max-width: 560px) {
    .hero__scroll { display: none; }
  }
</style>
