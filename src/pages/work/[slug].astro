---
import Base from '../../layouts/Base.astro';
import { projects, type Project } from '../../data/projects';

// One case-study page per project that has both a slug and rich `detail`.
export function getStaticPaths() {
  return projects
    .filter((p) => p.slug && p.detail)
    .map((p) => ({ params: { slug: p.slug! }, props: { project: p } }));
}

const { project } = Astro.props as { project: Project };
const d = project.detail!;
const repo = project.links.find((l) => /repo/i.test(l.label));

// Only asset sections with real content render, no dev-facing placeholders.
// Number the sections that actually appear so there are no gaps.
const sections = ['problem', 'architecture', 'stack', 'challenges', 'role'];
if (d.screenshots?.length) sections.push('screens');
if (d.video) sections.push('demo');
const n = (key: string) => String(sections.indexOf(key) + 1).padStart(2, '0');
---

<Base
  title={`${project.name}, Dean Ding`}
  description={d.oneLiner}
>
  <header class="topbar">
    <div class="shell topbar__inner">
      <a class="topbar__brand" href="/">
        <span class="topbar__mark">DD</span>
        <span class="topbar__path">dean_ding</span>
      </a>
      <a class="topbar__back" href="/#work">← All work</a>
    </div>
  </header>

  <main class="case">
    <!-- Hero -->
    <section class="section case__hero">
      <div class="shell">
        <span class="eyebrow" data-reveal>Case study</span>
        <h1 class="case__title" data-reveal>{project.name}</h1>
        <p class="case__lead" data-reveal>{d.oneLiner}</p>

        <div class="case__meta" data-reveal>
          <span class="case__status"><span class="status-dot"></span>{d.status}</span>
          <ul class="case__tags">
            {project.tech.map((t) => <li class="tag">{t}</li>)}
          </ul>
        </div>

        <div class="case__links" data-reveal>
          {repo && (
            <a href={repo.href} target="_blank" rel="noopener" class="case__cta">View repository ↗</a>
          )}
          {project.isPrivate && (
            <span class="case__private">Private repository, code shared on request</span>
          )}
        </div>
      </div>
    </section>

    <!-- Problem -->
    <section class="section case__block">
      <div class="shell case__grid">
        <span class="case__num" data-reveal>{n('problem')}</span>
        <div class="case__col">
          <h2 class="case__h" data-reveal>The problem</h2>
          <p class="case__p" data-reveal>{d.problem}</p>
        </div>
      </div>
    </section>

    <!-- Architecture -->
    <section class="section case__block case__block--alt">
      <div class="shell case__grid">
        <span class="case__num" data-reveal>{n('architecture')}</span>
        <div class="case__col">
          <h2 class="case__h" data-reveal>Architecture</h2>
          {d.architecture.map((para) => <p class="case__p" data-reveal>{para}</p>)}
          {d.diagram && (
            <figure class="case__diagram" data-reveal>
              <img src={d.diagram} alt={`${project.name} architecture diagram`} loading="lazy" />
            </figure>
          )}
          {d.systemUrl && (
            <figure class="case__sys" data-reveal>
              <div class="case__sysframe">
                <iframe src={d.systemUrl} title={`${project.name} system design`} loading="lazy"></iframe>
              </div>
              <figcaption class="case__syscap">
                <a href={d.systemUrl} target="_blank" rel="noopener">Open the full system diagram ↗</a>
              </figcaption>
            </figure>
          )}
          {d.workflowUrl && (
            <figure class="case__sys" data-reveal>
              <p class="case__syslead">And one workflow moving through that platform, a tax return from source documents to filed, showing where the agent does the prep, where the PII gate sits, and where a human owns the approval:</p>
              <div class="case__sysframe">
                <iframe src={d.workflowUrl} title={`${project.name} workflow, made reviewable`} loading="lazy"></iframe>
              </div>
              <figcaption class="case__syscap">
                <a href={d.workflowUrl} target="_blank" rel="noopener">Open the workflow diagram ↗</a>
              </figcaption>
            </figure>
          )}
        </div>
      </div>
    </section>

    <!-- Stack -->
    <section class="section case__block">
      <div class="shell case__grid">
        <span class="case__num" data-reveal>{n('stack')}</span>
        <div class="case__col">
          <h2 class="case__h" data-reveal>Tech stack</h2>
          <div class="stackgrid" data-reveal>
            {d.stack.map((g) => (
              <div class="stackgrid__group">
                <span class="stackgrid__label">{g.group}</span>
                <ul class="stackgrid__items">
                  {g.items.map((it) => <li>{it}</li>)}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Engineering challenges -->
    <section class="section case__block case__block--alt">
      <div class="shell case__grid">
        <span class="case__num" data-reveal>{n('challenges')}</span>
        <div class="case__col">
          <h2 class="case__h" data-reveal>Key engineering challenges</h2>
          <div class="challenges">
            {d.challenges.map((c) => (
              <article class="challenge" data-reveal>
                <h3 class="challenge__title">{c.title}</h3>
                <p class="challenge__body">{c.body}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Role -->
    <section class="section case__block">
      <div class="shell case__grid">
        <span class="case__num" data-reveal>{n('role')}</span>
        <div class="case__col">
          <h2 class="case__h" data-reveal>My role</h2>
          <p class="case__p" data-reveal>{d.role}</p>
        </div>
      </div>
    </section>

    {d.screenshots && d.screenshots.length > 0 && (
      <section class="section case__block case__block--alt">
        <div class="shell case__grid">
          <span class="case__num" data-reveal>{n('screens')}</span>
          <div class="case__col">
            <h2 class="case__h" data-reveal>Screens</h2>
            <div class="shots" data-reveal>
              {d.screenshots.map((src, i) => (
                <img class="shots__img" src={src} alt={`${project.name} screenshot ${i + 1}`} loading="lazy" />
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    {d.video && (
      <section class="section case__block">
        <div class="shell case__grid">
          <span class="case__num" data-reveal>{n('demo')}</span>
          <div class="case__col">
            <h2 class="case__h" data-reveal>Demo</h2>
            <div class="video" data-reveal>
              <iframe
                src={d.video}
                title={`${project.name} demo`}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          </div>
        </div>
      </section>
    )}

    <footer class="case__foot">
      <div class="shell">
        <a class="case__back" href="/#work">← Back to all work</a>
      </div>
    </footer>
  </main>
</Base>

<script>
  // This case-study page doesn't load the homepage motion bundle, so nothing
  // adds `is-ready` to release the anti-flash rule that hides [data-reveal].
  // Add it so the content shows. (The scroll choreography is a homepage-only
  // flourish; on these content pages, visibility is what matters.)
  document.documentElement.classList.add('is-ready');
</script>

<style>
  /* ---- top bar ---- */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(10px);
    background: linear-gradient(to bottom, rgba(10, 10, 12, 0.85), rgba(10, 10, 12, 0.4));
    border-bottom: 1px solid var(--line);
  }
  .topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .topbar__brand { display: flex; align-items: center; gap: 0.6rem; font-family: var(--font-mono); font-size: var(--fs-xs); }
  .topbar__mark {
    display: grid; place-items: center; width: 28px; height: 28px;
    border: 1px solid var(--line-strong); border-radius: 7px;
    font-weight: 700; color: var(--signal); letter-spacing: 0.05em;
  }
  .topbar__path { color: var(--text-dim); }
  .topbar__back {
    font-family: var(--font-mono); font-size: var(--fs-sm); color: var(--text-dim);
    transition: color 0.2s ease;
  }
  .topbar__back:hover { color: var(--signal); }

  /* ---- hero ---- */
  .case__hero { padding-block: clamp(3.5rem, 9vh, 6rem) clamp(2rem, 5vh, 3.5rem); }
  .case__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-3xl);
    line-height: var(--lh-tight);
    letter-spacing: -0.025em;
    margin-top: 1.1rem;
  }
  .case__lead {
    margin-top: 1.1rem;
    max-width: 60ch;
    color: var(--text-dim);
    font-size: var(--fs-lg);
    line-height: var(--lh-snug);
  }
  .case__meta {
    margin-top: 1.8rem;
    display: flex;
    align-items: center;
    gap: 1.4rem;
    flex-wrap: wrap;
  }
  .case__status {
    font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--text-faint);
    display: inline-flex; align-items: center; gap: 0.5em;
  }
  .status-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--signal); box-shadow: 0 0 8px var(--signal);
    animation: glow 1.8s ease-in-out infinite;
  }
  @keyframes glow { 50% { opacity: 0.4; } }
  .case__tags { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .case__links { margin-top: 1.8rem; display: flex; align-items: center; gap: 1.4rem; flex-wrap: wrap; }
  .case__cta {
    font-family: var(--font-mono); font-size: var(--fs-sm); color: var(--text);
    border-bottom: 1px solid var(--signal); padding-bottom: 2px;
    transition: color 0.2s ease;
  }
  .case__cta:hover { color: var(--signal); }
  .case__private { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--text-faint); }

  /* ---- content blocks ---- */
  .case__block { padding-block: clamp(3rem, 7vh, 5rem); border-top: 1px solid var(--line); }
  .case__block--alt {
    background: radial-gradient(80% 120% at 100% 0%, rgba(232, 178, 90, 0.025), transparent 55%);
  }
  .case__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem 2rem;
  }
  .case__num {
    font-family: var(--font-mono); font-size: var(--fs-xs); letter-spacing: 0.1em;
    color: var(--signal); opacity: 0.8;
  }
  .case__h {
    font-family: var(--font-display); font-weight: 600;
    font-size: var(--fs-xl);
    letter-spacing: -0.015em;
    margin-bottom: 1.1rem;
  }
  .case__p {
    color: var(--text-dim);
    font-size: var(--fs-md);
    line-height: 1.65;
    max-width: 68ch;
  }
  .case__p + .case__p { margin-top: 1rem; }

  /* ---- stack grid ---- */
  .stackgrid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.2rem;
  }
  .stackgrid__group {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-card);
    padding: 1.1rem 1.2rem;
  }
  .stackgrid__label {
    font-family: var(--font-mono); font-size: var(--fs-2xs); text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--signal);
  }
  .stackgrid__items {
    list-style: none; margin-top: 0.7rem; display: flex; flex-direction: column; gap: 0.4rem;
    font-size: var(--fs-sm); color: var(--text-dim);
  }
  .stackgrid__items li::before { content: '· '; color: var(--signal); }

  /* ---- challenges ---- */
  .challenges { display: grid; gap: 1rem; }
  .challenge {
    border: 1px solid var(--line); border-left: 2px solid var(--signal);
    border-radius: var(--radius); background: var(--bg-card);
    padding: 1.2rem 1.3rem;
  }
  .challenge__title {
    font-family: var(--font-display); font-weight: 600; font-size: var(--fs-lg);
    margin-bottom: 0.5rem;
  }
  .challenge__body { color: var(--text-dim); font-size: var(--fs-sm); line-height: var(--lh-normal); max-width: 68ch; }

  /* ---- screenshots / video / diagram ---- */
  .shots {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }
  .shots__img {
    width: 100%; border: 1px solid var(--line); border-radius: var(--radius);
  }
  .case__diagram { margin-top: 1.4rem; }
  .case__diagram img { width: 100%; border: 1px solid var(--line); border-radius: var(--radius); }
  /* Embedded, interactive system-design diagram (self-contained HTML). */
  .case__sys { margin-top: 1.6rem; }
  .case__sysframe {
    border: 1px solid var(--line-strong); border-radius: var(--radius); overflow: hidden;
    background: #14151a; height: clamp(460px, 62vh, 680px);
    box-shadow: 0 24px 60px -40px rgba(0, 0, 0, 0.7);
  }
  .case__sysframe iframe { width: 100%; height: 100%; border: 0; display: block; }
  .case__syslead { color: var(--text-dim); font-size: var(--fs-sm); line-height: 1.55; margin-bottom: 0.9rem; max-width: 68ch; }
  .case__syscap { margin-top: 0.8rem; font-family: var(--font-mono); font-size: var(--fs-xs); }
  .case__syscap a { color: var(--text); border-bottom: 1px solid var(--signal); padding-bottom: 2px; transition: color 0.2s ease; }
  .case__syscap a:hover { color: var(--signal); }
  .video {
    position: relative; aspect-ratio: 16 / 9; border-radius: var(--radius);
    overflow: hidden; border: 1px solid var(--line);
  }
  .video iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }

  /* ---- placeholders ---- */
  .placeholder {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.5rem; text-align: center;
    border: 1px dashed var(--line-strong); border-radius: var(--radius);
    background:
      repeating-linear-gradient(45deg, transparent, transparent 11px, rgba(255,255,255,0.015) 11px, rgba(255,255,255,0.015) 22px);
    color: var(--text-faint);
    padding: 1.4rem;
  }
  .placeholder--wide { min-height: 200px; margin-top: 1.4rem; }
  .placeholder--shot { min-height: 180px; }
  .placeholder--video { aspect-ratio: 16 / 9; }
  .placeholder__tag {
    font-family: var(--font-mono); font-size: var(--fs-xs); letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--text-dim);
  }
  .placeholder__hint { font-family: var(--font-mono); font-size: var(--fs-xs); }
  .placeholder__hint code {
    color: var(--signal); background: rgba(232, 178, 90, 0.08);
    padding: 0.1em 0.4em; border-radius: 5px;
  }

  /* ---- footer ---- */
  .case__foot { padding-block: clamp(2.5rem, 6vh, 4rem); border-top: 1px solid var(--line); }
  .case__back {
    font-family: var(--font-mono); font-size: var(--fs-sm); color: var(--text-dim);
    transition: color 0.2s ease;
  }
  .case__back:hover { color: var(--signal); }

  @media (min-width: 760px) {
    .case__grid { grid-template-columns: 3.5rem 1fr; }
  }
</style>
