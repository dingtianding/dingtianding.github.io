---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dean Ding, Software Engineer',
  description = 'Dean Ding, an Applied AI and backend engineer shipping production systems across fintech and healthcare, with deep accounting expertise, building trustworthy AI for finance and accounting.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/images/propic.jpeg', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0c" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <!-- Without JS the scroll-reveal elements never animate in, so make
         them visible. Keeps the site fully readable if the bundle fails. -->
    <noscript>
      <style>
        [data-reveal] { opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>
  </head>
  <body>
    <canvas id="ledger" class="ledger-bg" aria-hidden="true"></canvas>
    <div class="scroll-progress" aria-hidden="true"></div>
    <slot />
  </body>
</html>

<style>
  /* Ambient ledger canvas, sits above the page background grid,
     below all content. Pointer-transparent and decorative. */
  .ledger-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    /* Fade toward the edges so text areas stay legible. */
    -webkit-mask-image: radial-gradient(130% 100% at 50% 40%, #000 40%, transparent 88%);
    mask-image: radial-gradient(130% 100% at 50% 40%, #000 40%, transparent 88%);
  }
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 100%;
    transform: scaleX(0);
    transform-origin: 0 50%;
    background: linear-gradient(90deg, var(--signal-deep), var(--signal));
    z-index: 100;
    will-change: transform;
  }
</style>
